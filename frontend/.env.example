# Google Gemini API Configuration
# Get your free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_API_KEY_HERE

# Google News API Configuration (for hybrid fact-checking)
# Get your free API key from: https://newsapi.org/register
# This enables real-time article fetching for fact verification
# OPTIONAL: If not provided, app will fall back to AI-only analysis
NEWS_API_KEY=YOUR_NEWS_API_KEY_HERE

# Instructions:
# 1. Copy this file: cp .env.example .env.local
# 2. Replace YOUR_GEMINI_API_KEY_HERE with your actual Gemini API key
# 3. Replace YOUR_NEWS_API_KEY_HERE with your News API key (optional)
# 4. .env.local is git-ignored and not committed
